(defun sha512-set-k (i hi lo)
  (let ((addr (+ (e1000-state-base) (+ #x200 (* i 8)))))
    (setf (mem-ref addr :u32) hi)
    (setf (mem-ref (+ addr 4) :u32) lo)))

