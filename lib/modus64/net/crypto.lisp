;; ================================================================
;; Phase 7.7: Ed25519
;; ================================================================
;; Fixed memory layout:
;; base+0x500: curve parameter d (10 x u32 limbs = 40 bytes)
;; base+0x528: base point X (40 bytes)
;; base+0x550: base point Y (40 bytes)
;; base+0x578: sqrt(-1) mod p (40 bytes)
;; base+0x5A0: L bytes (group order, 32 bytes)
;; base+0x5C0: c bytes (L - 2^252, 16 bytes)
;; base+0x5D0: init flag (u32)

;; Store FE limbs to fixed memory
(defun fe-store-fixed (fe addr)
  (let ((off 0))
    (dotimes (i 10)
      (setf (mem-ref (+ addr off) :u32) (buf-read-u32 fe off))
      (setq off (+ off 4)))))

;; Load FE limbs from fixed memory
(defun fe-load-fixed (dst addr)
  (let ((off 0))
    (dotimes (i 10)
      (buf-write-u32 dst off (mem-ref (+ addr off) :u32))
      (setq off (+ off 4)))))

;; Compare two field elements (returns non-zero if equal)
(defun fe-equal (a b)
  (let ((ab (fe-to-bytes a))
        (bb (fe-to-bytes b))
        (result 1))
    (dotimes (i 32)
      (unless (eq (aref ab i) (aref bb i))
        (setq result 0)))
    result))

;; u^((p+3)/8) = u^(2^252-2) for square root
(defun fe-pow-sqrt (u)
  (let ((z2 (make-array 40))
        (z9 (make-array 40))
        (z11 (make-array 40))
        (t0 (make-array 40))
        (t1 (make-array 40)))
    (fe-sq z2 u)
    (fe-sq t0 z2)
    (fe-sq t1 t0)
    (fe-mul z9 u t1)
    (fe-mul z11 z2 z9)
    (fe-sq t0 z11)
    (fe-mul t0 z9 t0)
    ;; u^(2^10-1)
    (fe-sq t1 t0) (fe-sq-iter t1 4)
    (fe-mul t1 t1 t0)
    ;; u^(2^20-1)
    (fe-sq z2 t1) (fe-sq-iter z2 9)
    (fe-mul z2 z2 t1)
    ;; u^(2^40-1)
    (fe-sq z9 z2) (fe-sq-iter z9 19)
    (fe-mul z9 z9 z2)
    ;; u^(2^50-1)
    (fe-sq t0 z9) (fe-sq-iter t0 9)
    (fe-mul t0 t0 t1)
    ;; u^(2^100-1)
    (fe-sq t1 t0) (fe-sq-iter t1 49)
    (fe-mul t1 t1 t0)
    ;; u^(2^200-1)
    (fe-sq z2 t1) (fe-sq-iter z2 99)
    (fe-mul z2 z2 t1)
    ;; u^(2^250-1)
    (fe-sq z9 z2) (fe-sq-iter z9 49)
    (fe-mul z9 z9 t0)
    ;; u^(2^251-1) = (u^(2^250-1))^2 * u
    (fe-sq z9 z9)
    (fe-mul z9 z9 u)
    ;; u^(2^252-2) = (u^(2^251-1))^2
    (fe-sq t0 z9)
    t0))

;; Read L byte at index from fixed memory base+0x5A0
(defun ed-l-byte (i) (mem-ref (+ (e1000-state-base) (+ #x5A0 i)) :u8))
;; Read c byte at index from fixed memory base+0x5C0
(defun ed-c-byte (i) (mem-ref (+ (e1000-state-base) (+ #x5C0 i)) :u8))

