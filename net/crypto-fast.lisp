;;;; crypto-fast.lisp — Fast field element ops for little-endian 64-bit targets
;;;;
;;;; Load AFTER crypto.lisp (last-defun-wins).
;;;;
;;;; Replaces ALL fe-* functions with versions using mem-ref :u32 on raw array
;;;; addresses instead of buf-read-u32 (which does 4 aref + 3 ash + 3 logior).
;;;; Each mem-ref :u32 is ~3 instructions vs ~36 for buf-read-u32.
;;;;
;;;; NOTE: We do NOT override buf-read-u32 globally because ip.lisp needs
;;;; the big-endian version for network packet parsing.

;; ================================================================
;; fe-from-bytes: Convert 32 LE bytes to field element (10 limbs)
;; ================================================================
(defun fe-from-bytes (bytes)
  (let ((fe (make-array 40)))
    (let ((fb (+ (ash (logand fe (- 0 4)) 1) 8)))
      (setf (mem-ref fb :u32) (logand (buf-read-u32-le bytes 0) #x3FFFFFF))
      (setf (mem-ref (+ fb 4) :u32) (logand (ash (buf-read-u32-le bytes 3) -2) #x1FFFFFF))
      (setf (mem-ref (+ fb 8) :u32) (logand (ash (buf-read-u32-le bytes 6) -3) #x3FFFFFF))
      (setf (mem-ref (+ fb 12) :u32) (logand (ash (buf-read-u32-le bytes 9) -5) #x1FFFFFF))
      (setf (mem-ref (+ fb 16) :u32) (logand (ash (buf-read-u32-le bytes 12) -6) #x3FFFFFF))
      (setf (mem-ref (+ fb 20) :u32) (logand (buf-read-u32-le bytes 16) #x1FFFFFF))
      (setf (mem-ref (+ fb 24) :u32) (logand (ash (buf-read-u32-le bytes 19) -1) #x3FFFFFF))
      (setf (mem-ref (+ fb 28) :u32) (logand (ash (buf-read-u32-le bytes 22) -3) #x1FFFFFF))
      (setf (mem-ref (+ fb 32) :u32) (logand (ash (buf-read-u32-le bytes 25) -4) #x3FFFFFF))
      (setf (mem-ref (+ fb 36) :u32) (logand (ash (buf-read-u32-le bytes 28) -6) #x1FFFFFF)))
    fe))

;; ================================================================
;; fe-from-int: Convert integer to field element
;; ================================================================
(defun fe-from-int (n)
  (let ((fe (make-array 40)))
    (dotimes (i 40) (aset fe i 0))
    (let ((fb (+ (ash (logand fe (- 0 4)) 1) 8)))
      (setf (mem-ref fb :u32) (logand n #x3FFFFFF))
      (setf (mem-ref (+ fb 4) :u32) (logand (ash n -26) #x1FFFFFF)))
    fe))

;; ================================================================
;; fe-copy: Copy field element limbs
;; ================================================================
(defun fe-copy (dst src)
  (let ((db (+ (ash (logand dst (- 0 4)) 1) 8)))
    (let ((sb (+ (ash (logand src (- 0 4)) 1) 8)))
      (setf (mem-ref db :u32) (mem-ref sb :u32))
      (setf (mem-ref (+ db 4) :u32) (mem-ref (+ sb 4) :u32))
      (setf (mem-ref (+ db 8) :u32) (mem-ref (+ sb 8) :u32))
      (setf (mem-ref (+ db 12) :u32) (mem-ref (+ sb 12) :u32))
      (setf (mem-ref (+ db 16) :u32) (mem-ref (+ sb 16) :u32))
      (setf (mem-ref (+ db 20) :u32) (mem-ref (+ sb 20) :u32))
      (setf (mem-ref (+ db 24) :u32) (mem-ref (+ sb 24) :u32))
      (setf (mem-ref (+ db 28) :u32) (mem-ref (+ sb 28) :u32))
      (setf (mem-ref (+ db 32) :u32) (mem-ref (+ sb 32) :u32))
      (setf (mem-ref (+ db 36) :u32) (mem-ref (+ sb 36) :u32))))
  dst)

;; ================================================================
;; fe-add: Add two field elements
;; ================================================================
(defun fe-add (dst a b)
  (let ((db (+ (ash (logand dst (- 0 4)) 1) 8)))
    (let ((ab (+ (ash (logand a (- 0 4)) 1) 8)))
      (let ((bb (+ (ash (logand b (- 0 4)) 1) 8)))
        (setf (mem-ref db :u32) (+ (mem-ref ab :u32) (mem-ref bb :u32)))
        (setf (mem-ref (+ db 4) :u32) (+ (mem-ref (+ ab 4) :u32) (mem-ref (+ bb 4) :u32)))
        (setf (mem-ref (+ db 8) :u32) (+ (mem-ref (+ ab 8) :u32) (mem-ref (+ bb 8) :u32)))
        (setf (mem-ref (+ db 12) :u32) (+ (mem-ref (+ ab 12) :u32) (mem-ref (+ bb 12) :u32)))
        (setf (mem-ref (+ db 16) :u32) (+ (mem-ref (+ ab 16) :u32) (mem-ref (+ bb 16) :u32)))
        (setf (mem-ref (+ db 20) :u32) (+ (mem-ref (+ ab 20) :u32) (mem-ref (+ bb 20) :u32)))
        (setf (mem-ref (+ db 24) :u32) (+ (mem-ref (+ ab 24) :u32) (mem-ref (+ bb 24) :u32)))
        (setf (mem-ref (+ db 28) :u32) (+ (mem-ref (+ ab 28) :u32) (mem-ref (+ bb 28) :u32)))
        (setf (mem-ref (+ db 32) :u32) (+ (mem-ref (+ ab 32) :u32) (mem-ref (+ bb 32) :u32)))
        (setf (mem-ref (+ db 36) :u32) (+ (mem-ref (+ ab 36) :u32) (mem-ref (+ bb 36) :u32))))))
  dst)

;; ================================================================
;; fe-sub: Subtract field elements, add 2p to keep non-negative
;; ================================================================
(defun fe-sub (dst a b)
  (let ((db (+ (ash (logand dst (- 0 4)) 1) 8)))
    (let ((ab (+ (ash (logand a (- 0 4)) 1) 8)))
      (let ((bb (+ (ash (logand b (- 0 4)) 1) 8)))
        (setf (mem-ref db :u32) (+ (- (mem-ref ab :u32) (mem-ref bb :u32)) 134217690))
        (setf (mem-ref (+ db 4) :u32) (+ (- (mem-ref (+ ab 4) :u32) (mem-ref (+ bb 4) :u32)) 67108862))
        (setf (mem-ref (+ db 8) :u32) (+ (- (mem-ref (+ ab 8) :u32) (mem-ref (+ bb 8) :u32)) 134217726))
        (setf (mem-ref (+ db 12) :u32) (+ (- (mem-ref (+ ab 12) :u32) (mem-ref (+ bb 12) :u32)) 67108862))
        (setf (mem-ref (+ db 16) :u32) (+ (- (mem-ref (+ ab 16) :u32) (mem-ref (+ bb 16) :u32)) 134217726))
        (setf (mem-ref (+ db 20) :u32) (+ (- (mem-ref (+ ab 20) :u32) (mem-ref (+ bb 20) :u32)) 67108862))
        (setf (mem-ref (+ db 24) :u32) (+ (- (mem-ref (+ ab 24) :u32) (mem-ref (+ bb 24) :u32)) 134217726))
        (setf (mem-ref (+ db 28) :u32) (+ (- (mem-ref (+ ab 28) :u32) (mem-ref (+ bb 28) :u32)) 67108862))
        (setf (mem-ref (+ db 32) :u32) (+ (- (mem-ref (+ ab 32) :u32) (mem-ref (+ bb 32) :u32)) 134217726))
        (setf (mem-ref (+ db 36) :u32) (+ (- (mem-ref (+ ab 36) :u32) (mem-ref (+ bb 36) :u32)) 67108862)))))
  (fe-carry dst))

;; ================================================================
;; fe-carry: Carry propagation (even limbs 26 bits, odd 25 bits)
;; ================================================================
(defun fe-carry (h)
  (let ((hb (+ (ash (logand h (- 0 4)) 1) 8)))
    (let* ((v0 (mem-ref hb :u32))
           (c0 (ash v0 -26))
           (r0 (logand v0 #x3FFFFFF))
           (v1 (+ (mem-ref (+ hb 4) :u32) c0))
           (c1 (ash v1 -25))
           (r1 (logand v1 #x1FFFFFF))
           (v2 (+ (mem-ref (+ hb 8) :u32) c1))
           (c2 (ash v2 -26))
           (r2 (logand v2 #x3FFFFFF))
           (v3 (+ (mem-ref (+ hb 12) :u32) c2))
           (c3 (ash v3 -25))
           (r3 (logand v3 #x1FFFFFF))
           (v4 (+ (mem-ref (+ hb 16) :u32) c3))
           (c4 (ash v4 -26))
           (r4 (logand v4 #x3FFFFFF))
           (v5 (+ (mem-ref (+ hb 20) :u32) c4))
           (c5 (ash v5 -25))
           (r5 (logand v5 #x1FFFFFF))
           (v6 (+ (mem-ref (+ hb 24) :u32) c5))
           (c6 (ash v6 -26))
           (r6 (logand v6 #x3FFFFFF))
           (v7 (+ (mem-ref (+ hb 28) :u32) c6))
           (c7 (ash v7 -25))
           (r7 (logand v7 #x1FFFFFF))
           (v8 (+ (mem-ref (+ hb 32) :u32) c7))
           (c8 (ash v8 -26))
           (r8 (logand v8 #x3FFFFFF))
           (v9 (+ (mem-ref (+ hb 36) :u32) c8))
           (c9 (ash v9 -25))
           (r9 (logand v9 #x1FFFFFF))
           (r0w (+ r0 (* c9 19)))
           (c0b (ash r0w -26))
           (r0f (logand r0w #x3FFFFFF))
           (r1f (+ r1 c0b)))
      (setf (mem-ref hb :u32) r0f)
      (setf (mem-ref (+ hb 4) :u32) r1f)
      (setf (mem-ref (+ hb 8) :u32) r2)
      (setf (mem-ref (+ hb 12) :u32) r3)
      (setf (mem-ref (+ hb 16) :u32) r4)
      (setf (mem-ref (+ hb 20) :u32) r5)
      (setf (mem-ref (+ hb 24) :u32) r6)
      (setf (mem-ref (+ hb 28) :u32) r7)
      (setf (mem-ref (+ hb 32) :u32) r8)
      (setf (mem-ref (+ hb 36) :u32) r9)))
  h)

;; ================================================================
;; fe-reduce: Full reduction mod p = 2^255 - 19
;; ================================================================
(defun fe-reduce (h)
  (fe-carry h)
  (fe-carry h)
  (let ((hb (+ (ash (logand h (- 0 4)) 1) 8)))
    (let* ((t0 (+ (mem-ref hb :u32) 19))
           (c0 (ash t0 -26))
           (t0m (logand t0 #x3FFFFFF))
           (t1 (+ (mem-ref (+ hb 4) :u32) c0))
           (c1 (ash t1 -25))
           (t1m (logand t1 #x1FFFFFF))
           (t2 (+ (mem-ref (+ hb 8) :u32) c1))
           (c2 (ash t2 -26))
           (t2m (logand t2 #x3FFFFFF))
           (t3 (+ (mem-ref (+ hb 12) :u32) c2))
           (c3 (ash t3 -25))
           (t3m (logand t3 #x1FFFFFF))
           (t4 (+ (mem-ref (+ hb 16) :u32) c3))
           (c4 (ash t4 -26))
           (t4m (logand t4 #x3FFFFFF))
           (t5 (+ (mem-ref (+ hb 20) :u32) c4))
           (c5 (ash t5 -25))
           (t5m (logand t5 #x1FFFFFF))
           (t6 (+ (mem-ref (+ hb 24) :u32) c5))
           (c6 (ash t6 -26))
           (t6m (logand t6 #x3FFFFFF))
           (t7 (+ (mem-ref (+ hb 28) :u32) c6))
           (c7 (ash t7 -25))
           (t7m (logand t7 #x1FFFFFF))
           (t8 (+ (mem-ref (+ hb 32) :u32) c7))
           (c8 (ash t8 -26))
           (t8m (logand t8 #x3FFFFFF))
           (t9 (+ (mem-ref (+ hb 36) :u32) c8))
           (c9 (ash t9 -25))
           (t9m (logand t9 #x1FFFFFF)))
      (when (not (zerop c9))
        (setf (mem-ref hb :u32) t0m)
        (setf (mem-ref (+ hb 4) :u32) t1m)
        (setf (mem-ref (+ hb 8) :u32) t2m)
        (setf (mem-ref (+ hb 12) :u32) t3m)
        (setf (mem-ref (+ hb 16) :u32) t4m)
        (setf (mem-ref (+ hb 20) :u32) t5m)
        (setf (mem-ref (+ hb 24) :u32) t6m)
        (setf (mem-ref (+ hb 28) :u32) t7m)
        (setf (mem-ref (+ hb 32) :u32) t8m)
        (setf (mem-ref (+ hb 36) :u32) t9m))))
  h)

;; ================================================================
;; fe-to-bytes: Convert field element to 32 LE bytes
;; ================================================================
(defun fe-to-bytes (fe)
  (fe-reduce fe)
  (let ((fb (+ (ash (logand fe (- 0 4)) 1) 8)))
    (let ((r (make-array 32))
          (l0 (mem-ref fb :u32))
          (l1 (mem-ref (+ fb 4) :u32))
          (l2 (mem-ref (+ fb 8) :u32))
          (l3 (mem-ref (+ fb 12) :u32))
          (l4 (mem-ref (+ fb 16) :u32))
          (l5 (mem-ref (+ fb 20) :u32))
          (l6 (mem-ref (+ fb 24) :u32))
          (l7 (mem-ref (+ fb 28) :u32))
          (l8 (mem-ref (+ fb 32) :u32))
          (l9 (mem-ref (+ fb 36) :u32)))
      (aset r 0 (logand l0 #xFF))
      (aset r 1 (logand (ash l0 -8) #xFF))
      (aset r 2 (logand (ash l0 -16) #xFF))
      (aset r 3 (logand (logior (ash l0 -24) (ash l1 2)) #xFF))
      (aset r 4 (logand (ash l1 -6) #xFF))
      (aset r 5 (logand (ash l1 -14) #xFF))
      (aset r 6 (logand (logior (ash l1 -22) (ash l2 3)) #xFF))
      (aset r 7 (logand (ash l2 -5) #xFF))
      (aset r 8 (logand (ash l2 -13) #xFF))
      (aset r 9 (logand (logior (ash l2 -21) (ash l3 5)) #xFF))
      (aset r 10 (logand (ash l3 -3) #xFF))
      (aset r 11 (logand (ash l3 -11) #xFF))
      (aset r 12 (logand (logior (ash l3 -19) (ash l4 6)) #xFF))
      (aset r 13 (logand (ash l4 -2) #xFF))
      (aset r 14 (logand (ash l4 -10) #xFF))
      (aset r 15 (logand (ash l4 -18) #xFF))
      (aset r 16 (logand l5 #xFF))
      (aset r 17 (logand (ash l5 -8) #xFF))
      (aset r 18 (logand (ash l5 -16) #xFF))
      (aset r 19 (logand (logior (ash l5 -24) (ash l6 1)) #xFF))
      (aset r 20 (logand (ash l6 -7) #xFF))
      (aset r 21 (logand (ash l6 -15) #xFF))
      (aset r 22 (logand (logior (ash l6 -23) (ash l7 3)) #xFF))
      (aset r 23 (logand (ash l7 -5) #xFF))
      (aset r 24 (logand (ash l7 -13) #xFF))
      (aset r 25 (logand (logior (ash l7 -21) (ash l8 4)) #xFF))
      (aset r 26 (logand (ash l8 -4) #xFF))
      (aset r 27 (logand (ash l8 -12) #xFF))
      (aset r 28 (logand (logior (ash l8 -20) (ash l9 6)) #xFF))
      (aset r 29 (logand (ash l9 -2) #xFF))
      (aset r 30 (logand (ash l9 -10) #xFF))
      (aset r 31 (logand (ash l9 -18) #xFF))
      r)))

;; ================================================================
;; fe-store-fixed / fe-load-fixed
;; ================================================================
(defun fe-store-fixed (fe addr)
  (let ((fb (+ (ash (logand fe (- 0 4)) 1) 8)))
    (let ((off 0))
      (dotimes (i 10)
        (setf (mem-ref (+ addr off) :u32) (mem-ref (+ fb off) :u32))
        (setq off (+ off 4))))))

(defun fe-load-fixed (dst addr)
  (let ((db (+ (ash (logand dst (- 0 4)) 1) 8)))
    (let ((off 0))
      (dotimes (i 10)
        (setf (mem-ref (+ db off) :u32) (mem-ref (+ addr off) :u32))
        (setq off (+ off 4))))))

;; ================================================================
;; fe-mul: donna32 schoolbook with direct memory access
;; ================================================================
;; Single function matching original crypto.lisp structure exactly,
;; but using mem-ref :u32 for array access instead of buf-read-u32.
;; Uses: let (3 base addrs) → let (20 limbs) → let (14 precomputed)
;;     → let* (50+ products/carry) → 10 writes
;; Total ~90 frame slots, well within 120 limit.

(defun fe-mul (dst f g)
  (let ((db (+ (ash (logand dst (- 0 4)) 1) 8))
        (fb (+ (ash (logand f (- 0 4)) 1) 8))
        (gb (+ (ash (logand g (- 0 4)) 1) 8)))
    (let ((f0 (mem-ref fb :u32))
          (f1 (mem-ref (+ fb 4) :u32))
          (f2 (mem-ref (+ fb 8) :u32))
          (f3 (mem-ref (+ fb 12) :u32))
          (f4 (mem-ref (+ fb 16) :u32))
          (f5 (mem-ref (+ fb 20) :u32))
          (f6 (mem-ref (+ fb 24) :u32))
          (f7 (mem-ref (+ fb 28) :u32))
          (f8 (mem-ref (+ fb 32) :u32))
          (f9 (mem-ref (+ fb 36) :u32))
          (g0 (mem-ref gb :u32))
          (g1 (mem-ref (+ gb 4) :u32))
          (g2 (mem-ref (+ gb 8) :u32))
          (g3 (mem-ref (+ gb 12) :u32))
          (g4 (mem-ref (+ gb 16) :u32))
          (g5 (mem-ref (+ gb 20) :u32))
          (g6 (mem-ref (+ gb 24) :u32))
          (g7 (mem-ref (+ gb 28) :u32))
          (g8 (mem-ref (+ gb 32) :u32))
          (g9 (mem-ref (+ gb 36) :u32)))
      (let ((f1-2 (* 2 f1))
            (f3-2 (* 2 f3))
            (f5-2 (* 2 f5))
            (f7-2 (* 2 f7))
            (f9-2 (* 2 f9))
            (g1-19 (* 19 g1))
            (g2-19 (* 19 g2))
            (g3-19 (* 19 g3))
            (g4-19 (* 19 g4))
            (g5-19 (* 19 g5))
            (g6-19 (* 19 g6))
            (g7-19 (* 19 g7))
            (g8-19 (* 19 g8))
            (g9-19 (* 19 g9)))
        (let* ((h0 (+ (* f0 g0) (* f1-2 g9-19) (* f2 g8-19) (* f3-2 g7-19) (* f4 g6-19)
                     (* f5-2 g5-19) (* f6 g4-19) (* f7-2 g3-19) (* f8 g2-19) (* f9-2 g1-19)))
               (h1 (+ (* f0 g1) (* f1 g0) (* f2 g9-19) (* f3 g8-19) (* f4 g7-19)
                     (* f5 g6-19) (* f6 g5-19) (* f7 g4-19) (* f8 g3-19) (* f9 g2-19)))
               (h2 (+ (* f0 g2) (* f1-2 g1) (* f2 g0) (* f3-2 g9-19) (* f4 g8-19)
                     (* f5-2 g7-19) (* f6 g6-19) (* f7-2 g5-19) (* f8 g4-19) (* f9-2 g3-19)))
               (h3 (+ (* f0 g3) (* f1 g2) (* f2 g1) (* f3 g0) (* f4 g9-19)
                     (* f5 g8-19) (* f6 g7-19) (* f7 g6-19) (* f8 g5-19) (* f9 g4-19)))
               (h4 (+ (* f0 g4) (* f1-2 g3) (* f2 g2) (* f3-2 g1) (* f4 g0)
                     (* f5-2 g9-19) (* f6 g8-19) (* f7-2 g7-19) (* f8 g6-19) (* f9-2 g5-19)))
               (h5 (+ (* f0 g5) (* f1 g4) (* f2 g3) (* f3 g2) (* f4 g1)
                     (* f5 g0) (* f6 g9-19) (* f7 g8-19) (* f8 g7-19) (* f9 g6-19)))
               (h6 (+ (* f0 g6) (* f1-2 g5) (* f2 g4) (* f3-2 g3) (* f4 g2)
                     (* f5-2 g1) (* f6 g0) (* f7-2 g9-19) (* f8 g8-19) (* f9-2 g7-19)))
               (h7 (+ (* f0 g7) (* f1 g6) (* f2 g5) (* f3 g4) (* f4 g3)
                     (* f5 g2) (* f6 g1) (* f7 g0) (* f8 g9-19) (* f9 g8-19)))
               (h8 (+ (* f0 g8) (* f1-2 g7) (* f2 g6) (* f3-2 g5) (* f4 g4)
                     (* f5-2 g3) (* f6 g2) (* f7-2 g1) (* f8 g0) (* f9-2 g9-19)))
               (h9 (+ (* f0 g9) (* f1 g8) (* f2 g7) (* f3 g6) (* f4 g5)
                     (* f5 g4) (* f6 g3) (* f7 g2) (* f8 g1) (* f9 g0)))
               ;; Carry chain
               (c0 (ash h0 -26)) (r0 (logand h0 #x3FFFFFF))
               (h1b (+ h1 c0))
               (c1 (ash h1b -25)) (r1 (logand h1b #x1FFFFFF))
               (h2b (+ h2 c1))
               (c2 (ash h2b -26)) (r2 (logand h2b #x3FFFFFF))
               (h3b (+ h3 c2))
               (c3 (ash h3b -25)) (r3 (logand h3b #x1FFFFFF))
               (h4b (+ h4 c3))
               (c4 (ash h4b -26)) (r4 (logand h4b #x3FFFFFF))
               (h5b (+ h5 c4))
               (c5 (ash h5b -25)) (r5 (logand h5b #x1FFFFFF))
               (h6b (+ h6 c5))
               (c6 (ash h6b -26)) (r6 (logand h6b #x3FFFFFF))
               (h7b (+ h7 c6))
               (c7 (ash h7b -25)) (r7 (logand h7b #x1FFFFFF))
               (h8b (+ h8 c7))
               (c8 (ash h8b -26)) (r8 (logand h8b #x3FFFFFF))
               (h9b (+ h9 c8))
               (c9 (ash h9b -25)) (r9 (logand h9b #x1FFFFFF))
               (r0w (+ r0 (* c9 19)))
               (c0b (ash r0w -26))
               (r0f (logand r0w #x3FFFFFF))
               (r1f (+ r1 c0b)))
          (setf (mem-ref db :u32) r0f)
          (setf (mem-ref (+ db 4) :u32) r1f)
          (setf (mem-ref (+ db 8) :u32) r2)
          (setf (mem-ref (+ db 12) :u32) r3)
          (setf (mem-ref (+ db 16) :u32) r4)
          (setf (mem-ref (+ db 20) :u32) r5)
          (setf (mem-ref (+ db 24) :u32) r6)
          (setf (mem-ref (+ db 28) :u32) r7)
          (setf (mem-ref (+ db 32) :u32) r8)
          (setf (mem-ref (+ db 36) :u32) r9)))))
  dst)

(defun fe-sq (dst f)
  (fe-mul dst f f))

;; ================================================================
;; x25519: Override to fix byte-order mismatch
;; ================================================================
;; Original uses buf-write-u32 (big-endian) to init FE arrays, but our
;; fe-mul/fe-add etc. read via mem-ref :u32 (native LE). Fix by using
;; x25519-init-fe which writes limbs in native byte order.

(defun x25519-init-fe (dst n)
  ;; Initialize pre-allocated field element to integer n (native byte order)
  (let ((db (+ (ash (logand dst (- 0 4)) 1) 8)))
    (setf (mem-ref db :u32) (logand n #x3FFFFFF))
    (setf (mem-ref (+ db 4) :u32) (logand (ash n -26) #x1FFFFFF))
    (setf (mem-ref (+ db 8) :u32) 0)
    (setf (mem-ref (+ db 12) :u32) 0)
    (setf (mem-ref (+ db 16) :u32) 0)
    (setf (mem-ref (+ db 20) :u32) 0)
    (setf (mem-ref (+ db 24) :u32) 0)
    (setf (mem-ref (+ db 28) :u32) 0)
    (setf (mem-ref (+ db 32) :u32) 0)
    (setf (mem-ref (+ db 36) :u32) 0))
  dst)

(defun x25519 (k u)
  (let ((kc (make-array 32))
        (x1 (make-array 40))
        (x2 (make-array 40)) (z2 (make-array 40))
        (x3 (make-array 40)) (z3 (make-array 40))
        (a (make-array 40)) (aa (make-array 40))
        (b (make-array 40)) (bb (make-array 40))
        (fe-e (make-array 40)) (c (make-array 40))
        (d (make-array 40)) (da (make-array 40))
        (cb (make-array 40)) (t1 (make-array 40))
        (t2 (make-array 40)) (a24 (make-array 40))
        (swap 0) (pos 254))
    (dotimes (i 32) (aset kc i (aref k i)))
    (aset kc 0 (logand (aref kc 0) #xF8))
    (aset kc 31 (logand (aref kc 31) #x7F))
    (aset kc 31 (logior (aref kc 31) #x40))
    ;; Initialize FEs with native byte order (not buf-write-u32 which is BE)
    (fe-copy x1 (fe-from-bytes u))
    (x25519-init-fe x2 1)
    (x25519-init-fe z2 0)
    (fe-copy x3 x1)
    (x25519-init-fe z3 1)
    (x25519-init-fe a24 121665)
    ;; Montgomery ladder: 255 iterations
    (dotimes (iter 255)
      (let* ((byte-idx (ash pos -3))
             (bit-idx (logand pos 7))
             (byte-val (aref kc byte-idx))
             (mask (ash 1 bit-idx))
             (kt (if (zerop (logand byte-val mask)) 0 1)))
        (when (not (= kt swap))
          (fe-copy t1 x2) (fe-copy x2 x3) (fe-copy x3 t1)
          (fe-copy t1 z2) (fe-copy z2 z3) (fe-copy z3 t1))
        (setf swap kt)
        (fe-add a x2 z2)
        (fe-sq aa a)
        (fe-sub b x2 z2)
        (fe-sq bb b)
        (fe-sub fe-e aa bb)
        (fe-add c x3 z3)
        (fe-sub d x3 z3)
        (fe-mul da d a)
        (fe-mul cb c b)
        (fe-add t1 da cb)
        (fe-sq x3 t1)
        (fe-sub t1 da cb)
        (fe-sq t2 t1)
        (fe-mul z3 x1 t2)
        (fe-mul x2 aa bb)
        (fe-mul t1 a24 fe-e)
        (fe-add t2 aa t1)
        (fe-mul z2 fe-e t2))
      (setf pos (- pos 1))
      (when (zerop (logand iter 31)) (usb-keepalive)))
    (when (not (zerop swap))
      (fe-copy t1 x2) (fe-copy x2 x3) (fe-copy x3 t1)
      (fe-copy t1 z2) (fe-copy z2 z3) (fe-copy z3 t1))
    (fe-mul t1 x2 (fe-invert z2))
    (fe-to-bytes t1)))
