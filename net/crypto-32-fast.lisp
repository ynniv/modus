;;;; crypto-32-fast.lisp — Cons-free fe-mul/fe-sq for 32-bit targets
;;;;
;;;; Load AFTER crypto-32.lisp (last-defun-wins).
;;;;
;;;; Replaces pair-arithmetic fe-mul/fe-sq with memory-based versions.
;;;; Uses MVM mul26lo/mul26hi opcodes for hardware wide multiply.
;;;; All intermediate (hi, lo) pairs stored in scratch memory.
;;;;
;;;; Scratch memory layout at (fe-scratch-base):
;;;;   +0x00: f[0..9] + f-doubled[0..4] (15 × 4 = 60 bytes)
;;;;   +0x3C: g[0..9] (10 × 4 = 40 bytes)
;;;;   +0x64: h[0..9] 3-word (hi2/hi/lo) (10 × 12 = 120 bytes)
;;;;   +0xDC: result limbs r[0..9] (40 bytes)
;;;;
;;;; Uses 3-word accumulators to stay within 30-bit fixnum range.
;;;; Each h[k] word is kept < 2^26 via immediate carry propagation.
;;;;
;;;; fe-scratch-base is defined per architecture in arch-*.lisp

;; ================================================================
;; Read inputs to scratch memory
;; ================================================================

(defun fe-read-f-scratch (f)
  (let ((fb (+ (ash (logand f (- 0 4)) 1) 4)))
    (let ((base (fe-scratch-base)))
      (let ((i 0))
        (loop
          (when (>= i 40) (return 0))
          (setf (mem-ref (+ base i) :u32) (mem-ref (+ fb i) :u32))
          (setq i (+ i 4)))))))

(defun fe-precompute-fd ()
  (let ((base (fe-scratch-base)))
    (setf (mem-ref (+ base #x28) :u32) (* 2 (mem-ref (+ base #x04) :u32)))
    (setf (mem-ref (+ base #x2C) :u32) (* 2 (mem-ref (+ base #x0C) :u32)))
    (setf (mem-ref (+ base #x30) :u32) (* 2 (mem-ref (+ base #x14) :u32)))
    (setf (mem-ref (+ base #x34) :u32) (* 2 (mem-ref (+ base #x1C) :u32)))
    (setf (mem-ref (+ base #x38) :u32) (* 2 (mem-ref (+ base #x24) :u32)))))

(defun fe-read-g-scratch (g)
  (let ((gb (+ (ash (logand g (- 0 4)) 1) 4)))
    (let ((base (+ (fe-scratch-base) #x3C)))
      (let ((i 0))
        (loop
          (when (>= i 40) (return 0))
          (setf (mem-ref (+ base i) :u32) (mem-ref (+ gb i) :u32))
          (setq i (+ i 4)))))))

;; ================================================================
;; Multiply-accumulate using mul26lo/mul26hi opcodes
;; ================================================================
;;
;; Each fm-plain/fm-red takes (base k fi gi) where base = fe-scratch-base.
;; Addresses computed inline: f@base+fi*4, g@base+0x3C+gi*4, h@base+0x64+k*8.
;; This eliminates 6 function calls per multiply (was: fs-f-addr, fs-g-addr,
;; fs-h-addr each calling fe-scratch-base).

;; Read f[fi] from scratch
(defun fs-read-f (base fi)
  (let ((b base))
    (mem-ref (+ b (* fi 4)) :u32)))

;; Read g[gi] from scratch
(defun fs-read-g (base gi)
  (let ((b base))
    (mem-ref (+ b (+ #x3C (* gi 4))) :u32)))

;; Clear 3-word h[k] (hi2, hi, lo)
(defun fh-clear (base k)
  (let ((addr (+ base (+ #x64 (* k 12)))))
    (setf (mem-ref addr :u32) 0)
    (setf (mem-ref (+ addr 4) :u32) 0)
    (setf (mem-ref (+ addr 8) :u32) 0)))

;; Accumulate (rhi2, rhi, rlo) into 3-word h[k]
;; Each word kept < 2^26 via immediate carry propagation
(defun fh-acc-3 (base k rhi2 rhi rlo)
  (let ((b base))
    (let ((addr (+ b (+ #x64 (* k 12)))))
      (let ((lo (+ (mem-ref (+ addr 8) :u32) rlo)))
        (let ((carry-lo (ash lo -26)))
          (setf (mem-ref (+ addr 8) :u32) (logand lo 67108863))
          (let ((hi (+ (mem-ref (+ addr 4) :u32) (+ rhi carry-lo))))
            (let ((carry-hi (ash hi -26)))
              (setf (mem-ref (+ addr 4) :u32) (logand hi 67108863))
              (setf (mem-ref addr :u32)
                    (+ (mem-ref addr :u32) (+ rhi2 carry-hi))))))))))

;; Legacy 2-word fh-acc (used by diagnostic tests only)
(defun fh-acc (base k mhi mlo)
  (fh-acc-3 base k 0 mhi mlo))

;; Plain: f[fi] * g[gi] → accumulate to h[k]
(defun fm-plain (base k fi gi)
  (let ((b base))
    (let ((kk k))
      (let ((a (fs-read-f b fi)))
        (let ((bb (fs-read-g b gi)))
          (let ((mlo (mul26lo a bb)))
            (let ((mhi (mul26hi a bb)))
              (fh-acc-3 b kk 0 mhi mlo))))))))

;; Multiply (mhi, mlo) by 19 via hardware mul, accumulate to h[k]
;; Uses mul26lo/mul26hi to avoid 30-bit fixnum overflow
(defun fmul19-acc-3 (base k mhi mlo)
  (let ((b base))
    (let ((kk k))
      (let ((lo19-lo (mul26lo mlo 19)))
        (let ((lo19-hi (mul26hi mlo 19)))
          (let ((hi19-lo (mul26lo mhi 19)))
            (let ((hi19-hi (mul26hi mhi 19)))
              (let ((rhi (+ hi19-lo lo19-hi)))
                (fh-acc-3 b kk hi19-hi rhi lo19-lo)))))))))

;; Reduced: f[fi] * g[gi] * 19 → accumulate to h[k]
(defun fm-red (base k fi gi)
  (let ((b base))
    (let ((kk k))
      (let ((a (fs-read-f b fi)))
        (let ((bb (fs-read-g b gi)))
          (let ((mlo (mul26lo a bb)))
            (let ((mhi (mul26hi a bb)))
              (fmul19-acc-3 b kk mhi mlo))))))))

;; ================================================================
;; Compute h[0..9]
;; f indices: 0-9 = f0..f9, 10-14 = f1*2,f3*2,f5*2,f7*2,f9*2
;; g indices: 0-9 = g0..g9
;; ================================================================

(defun fe-compute-h0 (base)
  (let ((b base))
    (fh-clear b 0)
    (fm-plain b 0 0 0)
    (fm-red b 0 10 9)
    (fm-red b 0 2 8)
    (fm-red b 0 11 7)
    (fm-red b 0 4 6)
    (fm-red b 0 12 5)
    (fm-red b 0 6 4)
    (fm-red b 0 13 3)
    (fm-red b 0 8 2)
    (fm-red b 0 14 1)))

